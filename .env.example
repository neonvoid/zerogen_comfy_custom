# zerogen_comfy_custom — example environment
# Copy to `.env` (same folder) and fill in real values. NEVER commit your real .env.
# Values can also be set as real environment variables or typed directly on the nodes
# (node input > .env > process env, per src/zerogen_utils/api_keys.py).

# ─── Generation (required) ─────────────────────────────────────────────────
# Bearer API key for the Ark generation endpoint (Seedance gen / poll).
# Console: https://console.byteplus.com/ark  (international)  or Volcengine Ark (mainland).
ARK_API_KEY=

# ─── Asset library (required for the register nodes) ───────────────────────
# Access Key pair (AK/SK) — V4-signed calls to the trusted asset library
# (CreateAssetGroup / CreateAsset / GetAsset / ListAssets ...).
# Get from the BytePlus/Volcengine console under Access Keys (AK/SK), NOT the API key above.
ARK_ACCESS_KEY=
ARK_SECRET_KEY=

# ─── B2 staging (optional) ─────────────────────────────────────────────────
# Backblaze B2 (S3-compatible) bucket used to stage local images/videos to a public
# URL before CreateAsset (which is URL-pull only). Omit if you pass already-hosted URLs.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=your-bucket-name
B2_REGION=us-east-005

# ─── Local cache (optional) ────────────────────────────────────────────────
# Override where the BytePlus asset-register cache file is written.
# NV_BYTEPLUS_ASSET_CACHE_PATH=
